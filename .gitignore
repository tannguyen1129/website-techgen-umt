# =========================================
# Monorepo Git Ignore (umt-backend + umt-techgen)
# =========================================

# Dependencies
**/node_modules/
.pnp
.pnp.js
**/.yarn/install-state.gz
**/.yarn/cache
**/.yarn/patches
**/.yarn/plugins
**/.yarn/releases
**/.yarn/versions

# Environment & secrets
**/.env
**/.env.*
!**/.env.example
*.pem
*.key
id_rsa
id_rsa.pub

# Build outputs
**/dist/
**/build/
**/.next/
**/out/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage / test artifacts
coverage/
.nyc_output/

# IDE / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Docker / SSL / certbot local data
certbot/
ssl/

# App-specific generated/storage
**/uploads/
**/public/uploads/
**/.vercel/
**/.temp
**/.tmp
**/tmp/


# Repo history backups
.git-backups/
